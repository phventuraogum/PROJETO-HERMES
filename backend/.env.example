# ============================================================
#  Hermes ICP Radar — .env EXEMPLO
#  Copie para .env e preencha os valores.
#  NUNCA commite .env com valores reais!
# ============================================================

# ── Ambiente ─────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ── Autenticacao ─────────────────────────────────────────────
HERMES_AUTH_REQUIRED=false

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
SUPABASE_JWT_SECRET=seu_jwt_secret_aqui
SUPABASE_JWT_ISSUER=supabase
SUPABASE_JWT_AUDIENCE=authenticated

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=gerar_com_openssl_rand_hex_32

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8080,http://localhost:8081

# ── DuckDB ───────────────────────────────────────────────────
HERMES_DUCKDB_PATH=/data/cnpj.duckdb

# ── APIs de prospeccao ───────────────────────────────────────
OPENAI_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
BRAVE_SEARCH_API_KEY=
APOLLO_API_KEY=
HUNTER_API_KEY=
SNOVIO_USER_ID=
SNOVIO_SECRET=
PROXYCURL_API_KEY=

# ── Pagamentos (Asaas) ──────────────────────────────────────
ASAAS_API_KEY=sua_chave_asaas_aqui
ASAAS_SANDBOX=true
ASAAS_WEBHOOK_TOKEN=gerar_com_openssl_rand_hex_32

# ── Ploomes CRM ─────────────────────────────────────────────
PLOOMES_API_KEY=sua_user_key_do_ploomes
PLOOMES_FUNNEL_ID=

# ── n8n SDR Integration ─────────────────────────────────────
N8N_SDR_API_KEY=gerar_com_openssl_rand_hex_32
N8N_OUTBOUND_WEBHOOK=https://n8n.srv879715.hstgr.cloud/webhook/hermes-outbound

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30
